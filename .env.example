# ── Chat platform ─────────────────────────────────────────────────────────────
CHAT_PROVIDER=telegram

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.2

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAxxxx...

# Comma-separated list of enabled modes: dm, private_group, public_group
# dm            — bot replies to direct messages from any user
# private_group — bot replies only in allowed groups
# public_group  — bot replies in any public group or channel
TELEGRAM_ENABLED_MODES=dm,private_group

# Group IDs for private_group mode (comma-separated negative integers)
TELEGRAM_ALLOWED_GROUP_IDS=-100123456789,-100987654321

# Require @bot mention in groups? (true = only when mentioned, false = all messages)
TELEGRAM_REQUIRE_MENTION=true

# ── Discord ───────────────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=...

# Comma-separated list of enabled modes: dm, server
# dm     — bot replies to direct messages
# server — bot replies in guild text channels
# DISCORD_ENABLED_MODES=dm,server

# Channel IDs for server mode (comma-separated, empty = all channels)
# DISCORD_ALLOWED_CHANNEL_IDS=123456789012345678,987654321098765432

# Require @bot mention in server channels? (true = only when mentioned, false = all messages)
# DISCORD_REQUIRE_MENTION=true

# IMPORTANT: Enable Message Content Intent in Discord Developer Portal
# (Bot → Privileged Gateway Intents → Message Content Intent)

# ── Slack ─────────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...   (Bot User OAuth Token)
# SLACK_APP_TOKEN=xapp-...   (App-Level Token for Socket Mode)

# Comma-separated list of enabled modes: dm, channel
# dm      — bot replies to direct messages
# channel — bot replies in channels and group DMs
# SLACK_ENABLED_MODES=dm,channel

# Channel IDs for channel mode (comma-separated, empty = all channels)
# SLACK_ALLOWED_CHANNEL_IDS=C01234567,C89012345

# Require @bot mention in channels? (true = only when mentioned, false = all messages)
# SLACK_REQUIRE_MENTION=true

# ── RAG / Vector index ────────────────────────────────────────────────────────
# Index source: local or s3
FAISS_SOURCE=local
FAISS_INDEX_PATH=./data/faiss.index
FAISS_META_PATH=./data/chunks_meta.json

# S3 (used when FAISS_SOURCE=s3)
# S3_BUCKET=my-rag-bucket
# S3_INDEX_KEY=faiss/faiss.index
# S3_META_KEY=faiss/chunks_meta.json
# S3_VERSION_KEY=faiss/version.json
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# Minimum similarity threshold (0–1): queries below this score are rejected as off-topic
RAG_MIN_SIMILARITY=0.30

# Number of chunks passed to the LLM context
RAG_TOP_K=5

# Domain description used in the system prompt (fallback if user/system-prompt.md is absent)
RAG_DOMAIN_DESCRIPTION=OmniRAG project knowledge base: architecture, API, configuration, usage examples

# ── Confluence index source (indexer only) ───────────────────────────────────
# INDEX_SOURCE=confluence
# CONFLUENCE_DEPLOYMENT=cloud          # cloud | server
# CONFLUENCE_BASE_URL=https://example.atlassian.net
# CONFLUENCE_EMAIL=bot@example.com     # Cloud
# CONFLUENCE_API_TOKEN=...             # Cloud
# CONFLUENCE_PAT=...                   # Server/Data Center
# CONFLUENCE_SPACE_KEYS=OPS,ENG
# CONFLUENCE_CQL=type=page AND label=runbook
# CONFLUENCE_WORKERS=6

# ── Internal hot-reload endpoint ──────────────────────────────────────────────
# Enable on bot pods and expose only inside the cluster/network.
# HOT_RELOAD_ENABLED=true
# HOT_RELOAD_HOST=0.0.0.0
# HOT_RELOAD_PORT=8081
# HOT_RELOAD_TOKEN=replace-with-a-long-random-secret
# HOT_RELOAD_POLL_INTERVAL_SECONDS=60  # 0 disables automatic polling
